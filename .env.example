# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection — used by `bun run migrate` (and by Vercel
# during deploy via the vercel-build script). Find it under Supabase
# Dashboard → Project Settings → Database → "Connection string" → URI.
# Use the "Session pooler" URL (port 5432, ends with /postgres). Mark it
# sensitive on Vercel.
SUPABASE_DB_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (for invite + share emails)
RESEND_API_KEY=
RESEND_FROM="Trace <invites@yourdomain.com>"

# Cookie signing secret for public-share auth
SHARE_COOKIE_SECRET=replace-me-with-a-long-random-string

# Anthropic Claude — required for AI assistant + AI product search.
# If absent, AI features show a 503 error but the rest of the app works.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

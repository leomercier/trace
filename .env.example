# Supabase (required). The deploy-time migration script uses these same
# vars — no DB password needed. You do need to paste supabase/bootstrap.sql
# into Supabase Studio ONCE on a fresh project; after that every deploy
# applies new migrations automatically.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (for invite + share emails)
RESEND_API_KEY=
RESEND_FROM="Trace <invites@yourdomain.com>"

# Cookie signing secret for public-share auth
SHARE_COOKIE_SECRET=replace-me-with-a-long-random-string

# Anthropic Claude — required for AI assistant + AI product search.
# If absent, AI features show a 503 error but the rest of the app works.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

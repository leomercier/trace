# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (for invite + share emails)
RESEND_API_KEY=
RESEND_FROM="Trace <invites@yourdomain.com>"

# Cookie signing secret for public-share auth
SHARE_COOKIE_SECRET=replace-me-with-a-long-random-string
